{
  "id": "workflow_report_006_warning_baseline",
  "suite": "workflow-smoke",
  "suites": [
    "report-quality",
    "warning-baseline"
  ],
  "target": "workflow",
  "stage": "report",
  "input": {
    "query": "高铁站禁烟议题报告 warning 基线评估",
    "options": {
      "mode": "replay"
    }
  },
  "fixtures": {
    "mode": "replay",
    "recorded_tools": "tests/fixtures/workflow_report_006_warning_baseline/tools.json"
  },
  "expectations": {
    "required_fields": [
      "status",
      "stage",
      "artifacts",
      "metrics"
    ],
    "required_artifact_fields": [
      "report_html_file",
      "report_json_file"
    ],
    "max_latency_ms": 20000,
    "thresholds": {
      "structure_completeness": 1.0,
      "section_coverage": 1.0,
      "html_parse_success": 1.0,
      "relevance_score": 0.1
    },
    "consistency": {
      "warning_budget": 2
    }
  }
}

