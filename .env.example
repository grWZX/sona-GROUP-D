# =============================================================================
# Sona 环境变量模板
# -----------------------------------------------------------------------------
# 使用方法：复制本文件为项目根目录下的 `.env` 后填写真实值：
#   cp .env.example .env
# `.env` 已在 .gitignore 中，勿提交到 Git。
# 说明：以 `#` 开头的行是注释；留空则多数项使用代码内默认值。
# =============================================================================

# -----------------------------------------------------------------------------
# 一、大模型 API Key（至少配置 model.yaml 里用到的 provider 对应项）
# -----------------------------------------------------------------------------
# 与 config/model.yaml 中各 profile 的 api_key_env 对应，命名统一为 *APIKEY*

# OpenAI（或兼容 OpenAI 的网关）
# OPENAI_APIKEY=

# Google Gemini
# GEMINI_APIKEY=

# 通义千问 / DashScope
# QWEN_APIKEY=
# DASHSCOPE_APIKEY=
# 须为「大模型服务平台 / DashScope」控制台创建的 API-KEY（以 sk- 开头），
# 不是阿里云账号的 AccessKey ID/Secret。
# 若 Key 确定正确仍报 401，多为地域不一致：国内控制台开的 Key 用北京接入点；
# 国际站开的 Key 用新加坡等接入点。可显式指定兼容模式 base（覆盖 model.yaml）：
# SONA_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# SONA_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# DeepSeek
# DEEPSEEK_APIKEY=

# Kimi（Moonshot）
# KIMI_APIKEY=

# -----------------------------------------------------------------------------
# 二、搜索与工具
# -----------------------------------------------------------------------------

# BoCha 搜索（extract_search_terms 等）
# BOCHA_API_KEY=

# 抽词默认时间窗（天）、Bocha 条数上限（见 tools/extract_search_terms）
# SONA_EXTRACT_DEFAULT_RANGE_DAYS=30
# SONA_BOCHA_SEARCH_COUNT=20

# -----------------------------------------------------------------------------
# 三、NetInsight 数据采集（data_num / data_collect，可选）
# -----------------------------------------------------------------------------

# NETINSIGHT_USER=
# NETINSIGHT_PASS=
# NETINSIGHT_HEADLESS=true

# 登录超时（毫秒）、是否禁用代理（true 时走直连）
# SONA_NETINSIGHT_LOGIN_TIMEOUT_MS=90000
# SONA_NETINSIGHT_NO_PROXY=false

# -----------------------------------------------------------------------------
# 四、微博智搜 weibo_aisearch（Cookie 与抓取行为）
# -----------------------------------------------------------------------------
# 未配置 Cookie 时仍可能抓到公开页，但易被 Visitor 页拦截；建议配置其一：

# 方式 A：直接写 Cookie 头（从浏览器开发者工具复制，注意保密）
# SONA_WEIBO_COOKIE=

# 方式 B：Cookie 文件路径（支持 Playwright storage_state.json 或键值 JSON）
# SONA_WEIBO_COOKIE_PATH=

# 请求 Refer、抓取超时（秒）、是否启用 Playwright 回退
# SONA_WEIBO_AISEARCH_REFER=weibo_aisearch
# SONA_REFERENCE_FETCH_TIMEOUT_SEC=12
# SONA_WEIBO_AISEARCH_PLAYWRIGHT_FALLBACK=true

# -----------------------------------------------------------------------------
# 五、/wiki 知识库与 RAG（workflow/wiki_cli、workflow/wiki_rag）
# -----------------------------------------------------------------------------

# 本地 wiki 根目录（默认：项目下 opinion_analysis_kb/references/wiki；旧名「舆情深度分析」仍兼容）
# SONA_WIKI_ROOT=

# 检索最低分阈值，低于则视为「证据不足」
# SONA_WIKI_MIN_EVIDENCE_SCORE=0.09

# 是否用 LLM 基于检索片段合成答案（1/true 开启；测试常用 0）
# SONA_WIKI_USE_LLM=true

# 事件/梗类问题是否附加微博智搜摘录进 RAG 上下文
# SONA_WIKI_WEIBO_AUX=true

# RAG 合成温度、注入微博文本最大字符数
# SONA_WIKI_LLM_TEMPERATURE=0.25
# SONA_WIKI_WEIBO_MAX_CHARS=3500

# 半自动回流：高价值回答自动写入 wiki/output/_candidates（不自动入正式 output）
# SONA_WIKI_OUTPUT_CANDIDATE_ENABLED=true
# SONA_WIKI_HIGH_VALUE_THRESHOLD=75
# SONA_WIKI_CANDIDATE_MIN_SOURCES=3

# -----------------------------------------------------------------------------
# 六、LLM 调用通用（model/factory）
# -----------------------------------------------------------------------------

# SONA_LLM_TIMEOUT_SEC=180
# SONA_LLM_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# 七、事件分析工作流（部分常用项；更多见 workflow/event_analysis_pipeline）
# -----------------------------------------------------------------------------

# SONA_DATA_NUM_MAX_WORKERS=4
# SONA_DATA_COLLECT_MAX_WORKERS=3
# SONA_ANALYSIS_MAX_WORKERS=4
# SONA_RETURN_COUNT=2000
# SONA_DEFAULT_TIME_RANGE_DAYS=
# SONA_EVENT_WORKFLOW_DEBUG=false
# SONA_DEBUG_LOG_PATH=

# Graph RAG / Neo4j（可选）
# SONA_NEO4J_URI=neo4j://127.0.0.1:7687
# SONA_NEO4J_USER=neo4j
# SONA_NEO4J_PASSWORD=
# SONA_ENABLE_GRAPH_RAG=auto

# -----------------------------------------------------------------------------
# 八、热点 / 多引擎（tools/hottopics、utils/hot_topics_env 等，按需）
# -----------------------------------------------------------------------------

# INSIGHT_ENGINE_API_KEY=
# INSIGHT_ENGINE_BASE_URL=
# INSIGHT_ENGINE_MODEL_NAME=

# QUERY_ENGINE_API_KEY=
# QUERY_ENGINE_BASE_URL=
# QUERY_ENGINE_MODEL_NAME=

# KIMI_BASE_URL=
# KIMI_MODEL_NAME=

# -----------------------------------------------------------------------------
# 九、代理（数据采集走代理时）
# -----------------------------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=

# -----------------------------------------------------------------------------
# 十、CLI 与评测
# -----------------------------------------------------------------------------

# SONA_CLI_PROMPT_TOOLKIT=true

# EVAL_MODE=replay
# EVAL_DETERMINISTIC=1
# EVAL_STRICT_WARNINGS=0
